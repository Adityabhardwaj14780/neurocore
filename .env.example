# ============================================================================
# NeuroCore — Frontend Environment Configuration
# ============================================================================
#
# Vite only exposes variables prefixed with VITE_ to the client bundle.
# These are baked into the build at compile time — they are NOT runtime-configurable.
#
# SETUP:
#   1. Copy this file:  cp .env.example .env.local
#   2. Adjust values as needed.
#   3. NEVER commit .env.local to source control.
# ============================================================================

# Backend API base URL. No trailing slash.
# Dev: point to the local Express server.
# Prod: point to your deployed backend (e.g. https://api.neurocore.ai).
VITE_API_URL=http://localhost:5000
