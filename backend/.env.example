# ============================================================================
# Neuro Core — Backend Environment Configuration
# ============================================================================
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in EVERY value (or generate secrets as shown below).
#   3. NEVER commit .env to source control.
#
# GENERATING SECRETS (run each once):
#   openssl rand -base64 48
#
# IMPORTANT:
#   - In production, JWT_*_SECRET must be >= 32 chars and NOT the word "secret".
#   - All three secrets (JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, COOKIE_SECRET) must be DIFFERENT.
#   - MONGO_URI must point to a real Mongo instance (Atlas, self-hosted, etc.).
# ============================================================================

# ---- Runtime ----
NODE_ENV=development
PORT=5000

# ---- Frontend URL (used for CORS) ----
# Comma-separated list allowed in CORS_ORIGINS.
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=true

# ---- MongoDB ----
# Atlas example: mongodb+srv://user:pass@cluster.mongodb.net/neuro-core?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/neuro-core
MONGO_POOL_SIZE=10
MONGO_CONNECT_TIMEOUT_MS=10000

# ---- JWT (MUST be strong, unique, >= 32 chars in production) ----
JWT_ACCESS_SECRET=change-me-access-generate-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=change-me-refresh-generate-with-openssl-rand-base64-48
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_SEC=604800
JWT_ISSUER=neurocore-api
JWT_AUDIENCE=neurocore-client

# ---- Cookie signing (MUST be strong, unique, >= 32 chars in production) ----
COOKIE_SECRET=change-me-cookie-generate-with-openssl-rand-base64-48

# ---- Bcrypt ----
BCRYPT_SALT_ROUNDS=12

# ---- Account lockout ----
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ---- (Future) External services ----
# OPENAI_API_KEY=sk-...
# STRIPE_SECRET_KEY=sk_live_...
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@neurocore.ai
